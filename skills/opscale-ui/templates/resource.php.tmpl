<?php

namespace {{package_namespace}}\Nova;

use Illuminate\Http\Request;
{{#each field_imports}}
use {{.}};
{{/each}}
use Laravel\Nova\Http\Requests\NovaRequest;
use Laravel\Nova\Resource;
{{#if has_tabs}}
use Laravel\Nova\Tabs\Tab;
{{/if}}
use {{package_namespace}}\Models\{{model_name}} as {{model_name}}Model;
{{#if has_status}}
use {{package_namespace}}\Models\Enums\{{status_enum}};
{{/if}}
{{#each related_resource_imports}}
use {{.}};
{{/each}}
{{#if uses_field_trait}}
use {{package_namespace}}\Nova\Concerns\{{model_name}}Fields;
{{/if}}

/**
 * @extends Resource<{{model_name}}Model>
 */
class {{model_name}} extends Resource
{
{{#if uses_field_trait}}
    use {{model_name}}Fields;

{{/if}}
    public static $model = {{model_name}}Model::class;

    public static $title = '{{title_column}}';

    public static $search = [{{#each search_columns}}'{{.}}'{{#unless @last}}, {{/unless}}{{/each}}];

    public static function uriKey(): string
    {
        return '{{uri_key}}';
    }

    public static function label(): string
    {
        return __('{{label}}');
    }

    public static function singularLabel(): string
    {
        return __('{{singular_label}}');
    }

    public function fields(NovaRequest $request): array
    {
{{#if has_tabs}}
        return [
            Tab::group(__('{{model_name}}'), [
                Tab::make(__('Details'), [
{{#if uses_field_trait}}
                    ...$this->coreFields($request),
{{/if}}
{{#if has_status}}

                    Badge::make(__('Status'), 'status')
                        ->map([
{{#each status_badge.map}}
                            {{status_enum}}::{{case}}->value => '{{color}}',
{{/each}}
                        ])
                        ->labels([
{{#each status_badge.labels}}
                            {{status_enum}}::{{case}}->value => __('{{label}}'),
{{/each}}
                        ])
                        ->sortable(),
{{/if}}

                    DateTime::make(__('Created At'), 'created_at')
                        ->displayUsing(fn ($value) => $value?->diffForHumans())
                        ->exceptOnForms()
                        ->sortable(),

                    DateTime::make(__('Updated At'), 'updated_at')
                        ->displayUsing(fn ($value) => $value?->diffForHumans())
                        ->exceptOnForms(),
                ]),
{{#each has_many_relationships}}

                Tab::make(__('{{label}}'), [
                    HasMany::make(__('{{label}}'), '{{name}}', {{related_resource}}::class),
                ]),
{{/each}}
            ]),
        ];
{{else}}
        return [
{{#if uses_field_trait}}
            ...$this->coreFields($request),
{{/if}}
{{#if has_status}}

            Badge::make(__('Status'), 'status')
                ->map([
{{#each status_badge.map}}
                    {{status_enum}}::{{case}}->value => '{{color}}',
{{/each}}
                ])
                ->labels([
{{#each status_badge.labels}}
                    {{status_enum}}::{{case}}->value => __('{{label}}'),
{{/each}}
                ])
                ->sortable(),
{{/if}}

            DateTime::make(__('Created At'), 'created_at')
                ->displayUsing(fn ($value) => $value?->diffForHumans())
                ->exceptOnForms()
                ->sortable(),

            DateTime::make(__('Updated At'), 'updated_at')
                ->displayUsing(fn ($value) => $value?->diffForHumans())
                ->exceptOnForms(),
        ];
{{/if}}
    }

    public function fieldsForCreate(): array
    {
        return [
{{#if uses_field_trait}}
            ...$this->coreFields(app(NovaRequest::class)),
{{/if}}
        ];
    }
}
